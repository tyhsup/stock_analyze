{% extends "base.html" %}

{% block title %}Institutional Chips Analysis - StockAIG{% endblock %}

{% block content %}
<div class="row mb-3">
    <div class="col-12">
        <div class="d-flex justify-content-between align-items-center bg-white p-4 rounded shadow-sm border-0">
            <div>
                <h2 class="display-6 fw-bold mb-1"><i class="bi bi-person-check text-primary me-2"></i>Institutional Investor Dashboard</h2>
                <p class="text-muted mb-0">Analysis of daily buy/sell activity from Foreign, Trust, and Dealer institutions.</p>
            </div>
            <div id="refresh-controls" class="d-flex align-items-center">
                <div id="refresh-progress-container" class="me-3" style="display: none; min-width: 200px;">
                    <div class="d-flex justify-content-between mb-1 small">
                        <span id="refresh-status-text">Updating...</span>
                        <span id="refresh-percent">0%</span>
                    </div>
                    <div class="progress" style="height: 6px;">
                        <div id="refresh-progress-bar" class="progress-bar progress-bar-striped progress-bar-animated" role="progressbar" style="width: 0%"></div>
                    </div>
                </div>
                <button id="btn-refresh-tw" class="btn btn-outline-primary btn-sm rounded-pill px-3 shadow-sm hover-scale me-2">
                    <i class="bi bi-arrow-clockwise me-1"></i> Update TW Data
                </button>
                <button id="btn-refresh-us" class="btn btn-outline-secondary btn-sm rounded-pill px-3 shadow-sm hover-scale">
                    <i class="bi bi-arrow-clockwise me-1"></i> Update US Data
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Market Selector Tabs -->
<style>
    .market-tab.nav-link:not(.active) {
        background-color: white !important;
        color: var(--bs-secondary);
    }
    [data-bs-theme="dark"] .market-tab.nav-link:not(.active) {
        background-color: var(--card-bg) !important;
        color: var(--text-secondary) !important;
        border-color: var(--card-border) !important;
    }
</style>
<ul class="nav nav-pills mb-4" id="market-tabs" role="tablist">
    <li class="nav-item" role="presentation">
        <button class="nav-link active rounded-pill px-4 me-2 shadow-sm border market-tab" id="tw-tab" data-bs-toggle="pill" data-bs-target="#tw-content" type="button" role="tab" aria-selected="true">
            <span class="fs-5">🇹🇼 Taiwan Market</span>
        </button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link rounded-pill px-4 shadow-sm border market-tab" id="us-tab" data-bs-toggle="pill" data-bs-target="#us-content" type="button" role="tab" aria-selected="false">
            <span class="fs-5">🇺🇸 USA Market</span>
        </button>
    </li>
</ul>

<div class="tab-content" id="market-tabs-content">
    <!-- Taiwan Content -->
    <div class="tab-pane fade show active" id="tw-content" role="tabpanel" aria-labelledby="tw-tab">
        <div class="d-flex justify-content-end mb-3">
            {% if buysell_json %}
            <span class="badge bg-light text-dark border p-2 rounded-pill shadow-sm">
                <i class="bi bi-calendar-event me-1 text-primary"></i> TW Latest Date: {{ buysell_json.latest_date }}
            </span>
            {% endif %}
        </div>

{% if error %}
<div class="alert alert-danger shadow-sm border-0 d-flex align-items-center" role="alert">
    <i class="bi bi-exclamation-triangle-fill me-2 fs-4"></i>
    <div>{{ error }}</div>
</div>
{% endif %}

<!-- Sub Tabs for Taiwan Market -->
<ul class="nav nav-tabs mb-4" id="tw-sub-tabs" role="tablist">
    <li class="nav-item" role="presentation">
        <button class="nav-link active fw-bold" id="tw-chips-tab" data-bs-toggle="tab" data-bs-target="#tw-chips-panel" type="button" role="tab" aria-controls="tw-chips-panel" aria-selected="true">
            <i class="bi bi-bar-chart-steps me-1"></i> 籌碼買賣超
        </button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link fw-bold" id="tw-industry-tab" data-bs-toggle="tab" data-bs-target="#tw-industry-panel" type="button" role="tab" aria-controls="tw-industry-panel" aria-selected="false">
            <i class="bi bi-grid-3x3-gap me-1"></i> 產業資金流向
        </button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link fw-bold" id="tw-master-tab" data-bs-toggle="tab" data-bs-target="#tw-master-panel" type="button" role="tab" aria-controls="tw-master-panel" aria-selected="false">
            <i class="bi bi-award me-1"></i> 大師選股
        </button>
    </li>
</ul>

<div class="tab-content" id="tw-sub-tabs-content">
    <!-- Tab Panel 1: 籌碼買賣超 -->
    <div class="tab-pane fade show active" id="tw-chips-panel" role="tabpanel" aria-labelledby="tw-chips-tab">
        <!-- Section 1: Market Leaders & Laggards (Top 10 Buyers/Sellers) -->
        <div class="row mb-4">
            <div class="col-12 mb-4">
                <div class="card border-0 shadow-sm">
                    <div class="card-header bg-white border-0 py-3 d-flex align-items-center">
                        <div class="bg-success bg-opacity-10 p-2 rounded me-3">
                            <i class="bi bi-graph-up-arrow text-success fs-5"></i>
                        </div>
                        <h5 class="card-title fw-bold mb-0">Institutional Buy - Top 10 Buyers</h5>
                    </div>
                    <div class="card-body">
                        <div id="top-buyers-chart" style="min-height: 500px;"></div>
                        <div class="mt-3 small text-muted">Showing combined net buying volume from the 3 major institutions (TW Market).</div>
                    </div>
                </div>
            </div>
            <div class="col-12">
                <div class="card border-0 shadow-sm">
                    <div class="card-header bg-white border-0 py-3 d-flex align-items-center">
                        <div class="bg-danger bg-opacity-10 p-2 rounded me-3">
                            <i class="bi bi-graph-down-arrow text-danger fs-5"></i>
                        </div>
                        <h5 class="card-title fw-bold mb-0">Institutional Sell - Top 10 Sellers</h5>
                    </div>
                    <div class="card-body">
                        <div id="top-sellers-chart" style="min-height: 500px;"></div>
                        <div class="mt-3 small text-muted">Showing combined net selling volume from the 3 major institutions (TW Market).</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Section 2: TOP 5 Institutional Chips - Last 5 Days (Individual Charts) -->
        <div class="row mb-4">
            <div class="col-12">
                <div class="card border-0 shadow-sm">
                    <div class="card-header bg-white border-0 py-3 d-flex align-items-center">
                        <div class="bg-primary bg-opacity-10 p-2 rounded me-3">
                            <i class="bi bi-layers-half text-primary fs-5"></i>
                        </div>
                        <h5 class="card-title fw-bold mb-0">TOP 5 Institutional Investor Activity - Last 5 Days</h5>
                    </div>
                    <div class="card-body">
                        <div class="row" id="top-5-container">
                            <!-- JavaScript will inject charts here -->
                            <div class="col-12 text-center py-5" id="top-5-loader">
                                <div class="spinner-border text-primary" role="status">
                                    <span class="visually-hidden">Loading charts...</span>
                                </div>
                                <p class="mt-2 text-muted">Generating per-stock chip analysis...</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Tab Panel 2: 產業資金流向 -->
    <div class="tab-pane fade" id="tw-industry-panel" role="tabpanel" aria-labelledby="tw-industry-tab">
        <!-- Control Bar -->
        <div class="row mb-4">
            <div class="col-12">
                <div class="card border-0 shadow-sm p-4 bg-light">
                    <div class="row align-items-center g-3">
                        <div class="col-md-4">
                            <label class="form-label fw-bold mb-2"><i class="bi bi-calendar-range me-1 text-primary"></i> 分析天數</label>
                            <div class="btn-group w-100" role="group" id="days-btn-group">
                                <button type="button" class="btn btn-outline-primary" data-days="1">1 天</button>
                                <button type="button" class="btn btn-outline-primary" data-days="5">5 天</button>
                                <button type="button" class="btn btn-outline-primary active" data-days="10">10 天</button>
                            </div>
                        </div>
                        <div class="col-md-8">
                            <label class="form-label fw-bold mb-2"><i class="bi bi-sliders me-1 text-primary"></i> 籌碼評分模型權重調整</label>
                            <div class="row g-2">
                                <div class="col-sm-4">
                                    <div class="small text-muted d-flex justify-content-between">
                                        <span>法人力道:</span> <span id="w1-val" class="fw-bold">50%</span>
                                    </div>
                                    <input type="range" class="form-range" id="w1-slider" min="0" max="100" value="50">
                                </div>
                                <div class="col-sm-4">
                                    <div class="small text-muted d-flex justify-content-between">
                                        <span>連續天數:</span> <span id="w2-val" class="fw-bold">30%</span>
                                    </div>
                                    <input type="range" class="form-range" id="w2-slider" min="0" max="100" value="30">
                                </div>
                                <div class="col-sm-4">
                                    <div class="small text-muted d-flex justify-content-between">
                                        <span>資券沉澱:</span> <span id="w3-val" class="fw-bold">20%</span>
                                    </div>
                                    <input type="range" class="form-range" id="w3-slider" min="0" max="100" value="20">
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="d-flex justify-content-end mt-3">
                        <button type="button" class="btn btn-primary px-4 shadow-sm hover-scale rounded-pill fw-bold" id="btn-recalculate-flow">
                            <i class="bi bi-arrow-repeat me-1"></i> 重新計算
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Heatmap Treemap -->
        <div class="row mb-4">
            <div class="col-12">
                <div class="card border-0 shadow-sm position-relative">
                    <div class="card-header bg-white border-0 py-3 d-flex align-items-center">
                        <div class="bg-success bg-opacity-10 p-2 rounded me-3">
                            <i class="bi bi-grid-3x3-gap text-success fs-5"></i>
                        </div>
                        <h5 class="card-title fw-bold mb-0">產業資金流向熱力圖</h5>
                    </div>
                    <div class="card-body position-relative">
                        <div id="industry-flow-loader" class="position-absolute top-50 start-50 translate-middle text-center py-5 d-none" style="z-index: 10; background: rgba(255,255,255,0.8); width: 100%; height: 100%; display: flex; flex-direction: column; align-items: center; justify-content: center; border-radius: 1rem;">
                            <div class="spinner-border text-primary" role="status">
                                <span class="visually-hidden">Loading data...</span>
                            </div>
                            <p class="mt-2 text-muted fw-bold">計算產業籌碼與評分中...</p>
                        </div>
                        <div id="industry-treemap-chart" style="min-height: 500px;"></div>
                        <div class="mt-3 small text-muted d-flex justify-content-between align-items-center flex-wrap">
                            <span>提示：區塊面積代表「產業總成交值」，顏色深淺代表「三大法人淨流入金額」（紅買超/綠賣超/灰中性）</span>
                            <span class="fw-bold"><i class="bi bi-info-circle text-primary"></i> 點擊產業區塊可展開下方個股排行</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Top 10 Stocks Table Card -->
        <div class="row d-none mb-4" id="top-stocks-row">
            <div class="col-12">
                <div class="card border-0 shadow-sm border-top border-4 border-primary">
                    <div class="card-header bg-white border-0 py-3 d-flex justify-content-between align-items-center">
                        <div class="d-flex align-items-center">
                            <div class="bg-warning bg-opacity-10 p-2 rounded me-3">
                                <i class="bi bi-trophy text-warning fs-5"></i>
                            </div>
                            <h5 class="card-title fw-bold mb-0" id="top-stocks-title">最受看好前 10 家公司</h5>
                        </div>
                        <span class="badge bg-primary rounded-pill px-3 py-2 fw-bold" id="top-stocks-badge">篩選出 10 檔個股</span>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover table-striped mb-0 align-middle">
                                <thead class="table-light">
                                    <tr>
                                        <th class="ps-4" style="width: 80px;">排名</th>
                                        <th style="width: 120px;">代號</th>
                                        <th>名稱</th>
                                        <th style="width: 140px;">收盤價</th>
                                        <th style="width: 220px;">三大法人買賣超 (千元)</th>
                                        <th style="width: 160px;">連續買超天數</th>
                                        <th class="pe-4 text-end" style="width: 150px;">綜合評分</th>
                                    </tr>
                                </thead>
                                <tbody id="top-stocks-tbody">
                                    <!-- Injected dynamically by Javascript -->
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Tab Panel 3: 大師選股 -->
    <div class="tab-pane fade" id="tw-master-panel" role="tabpanel" aria-labelledby="tw-master-tab">
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-white border-0 py-3 d-flex flex-wrap justify-content-between align-items-center gap-3">
                <div class="d-flex align-items-center">
                    <div class="bg-primary bg-opacity-10 p-2 rounded me-3">
                        <i class="bi bi-award text-primary fs-5"></i>
                    </div>
                    <div>
                        <h5 class="card-title fw-bold mb-0" id="tw-master-title">大師選股 - 巴菲特價值投資法則 (台股)</h5>
                        <small class="text-muted" id="tw-master-desc">篩選標準：ROE &ge; 15% | 營業毛利率 &ge; 30% | 負債比率 &le; 50% | 淨利正成長</small>
                    </div>
                </div>
                <div class="d-flex align-items-center gap-2 flex-wrap">
                    <label for="tw-master-select" class="form-label mb-0 small fw-bold text-muted">選擇流派:</label>
                    <select id="tw-master-select" class="form-select form-select-sm rounded-pill px-3" style="width: 220px;">
                        <option value="buffett" selected>巴菲特 (價值投資)</option>
                        <option value="lynch">彼得·林區 (合理成長)</option>
                        <option value="oneil">威廉·歐尼爾 (CANSLIM)</option>
                    </select>
                    <label for="tw-master-industry-select" class="form-label mb-0 small fw-bold text-muted ms-2">選擇產業:</label>
                    <select id="tw-master-industry-select" class="form-select form-select-sm rounded-pill px-3" style="width: 180px;">
                        <option value="all" selected>All (全部產業)</option>
                    </select>
                    <button class="btn btn-sm btn-outline-primary rounded-pill px-3 shadow-sm hover-scale ms-2" id="btn-refresh-tw-master">
                        <i class="bi bi-arrow-repeat me-1"></i> 強制重新計算
                    </button>
                </div>
            </div>
            <div class="card-body p-0">
                <div id="tw-master-loader" class="text-center py-5">
                    <div class="spinner-border text-primary" role="status"></div>
                    <p class="mt-2 text-muted fw-bold">正在分析台股基本面數據並進行評分篩選...</p>
                </div>
                <div class="table-responsive" id="tw-master-table-wrap" style="display:none;">
                    <table class="table table-hover table-striped mb-0 align-middle">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-4" style="width: 80px;">排名</th>
                                <th style="width: 120px;">代號</th>
                                <th>名稱</th>
                                <th>產業別</th>
                                <th>最新收盤價</th>
                                <th id="th-tw-metrics-1">ROE</th>
                                <th id="th-tw-metrics-2">營業毛利率</th>
                                <th id="th-tw-metrics-3">負債比率</th>
                                <th id="th-tw-metrics-4">淨利成長率</th>
                                <th class="pe-4 text-end" style="width: 150px;">綜合評分</th>
                            </tr>
                        </thead>
                        <tbody id="tw-master-tbody">
                            <!-- Injected dynamically by Javascript -->
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
    </div>

    <!-- USA Content -->
    <div class="tab-pane fade" id="us-content" role="tabpanel" aria-labelledby="us-tab">
        {% if error and "US chip data" in error %}
        <div class="alert alert-danger shadow-sm border-0 d-flex align-items-center mb-3" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2 fs-4"></i>
            <div>{{ error }}</div>
        </div>
        {% endif %}

        <!-- USA Market Header: Ticker Selector + Sync Controls -->
        <div class="row mb-3">
            <div class="col-12">
                <div class="d-flex justify-content-between align-items-center bg-white p-3 rounded shadow-sm flex-wrap gap-2">
                    <div class="d-flex align-items-center gap-3 flex-wrap">
                        <div class="d-flex align-items-center gap-2">
                            <label for="sec-ticker-select" class="fw-bold text-nowrap mb-0">
                                <i class="bi bi-search text-primary me-1"></i>SEC Ticker:
                            </label>
                            <input type="text" id="sec-ticker-search" class="form-control form-control-sm" placeholder="Search..." style="width: 120px;">
                            <select id="sec-ticker-select" class="form-select form-select-sm" style="min-width: 200px;">
                                <option value="AAPL" selected>AAPL - Apple</option>
                                <option value="MSFT">MSFT - Microsoft</option>
                                <option value="NVDA">NVDA - Nvidia</option>
                                <option value="TSLA">TSLA - Tesla</option>
                                <option value="AMZN">AMZN - Amazon</option>
                                <option value="META">META - Meta</option>
                                <option value="GOOGL">GOOGL - Google</option>
                            </select>
                        </div>
                        <button id="btn-load-more-tickers" class="btn btn-outline-secondary btn-sm rounded-pill px-3">
                            <i class="bi bi-list-ul me-1"></i> Load Full List
                        </button>
                    </div>
                    <div class="d-flex align-items-center gap-2">
                        <div id="sec-sync-status" class="me-2 small text-muted" style="display:none;">
                            <div class="spinner-border spinner-border-sm text-primary me-1" role="status"></div>
                            <span id="sec-sync-text">Syncing...</span>
                        </div>
                        <button id="btn-sync-13f" class="btn btn-sm btn-outline-primary rounded-pill px-3 shadow-sm hover-scale">
                            <i class="bi bi-cloud-download me-1"></i> Sync 13F
                        </button>
                        <button id="btn-sync-insider" class="btn btn-sm btn-outline-warning rounded-pill px-3 shadow-sm hover-scale">
                            <i class="bi bi-cloud-download me-1"></i> Sync Insider/Fin
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- USA Sub Tabs -->
        <ul class="nav nav-tabs mb-4" id="us-sub-tabs" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link active fw-bold" id="us-holders-tab" data-bs-toggle="tab" data-bs-target="#us-holders-panel" type="button" role="tab" aria-selected="true">
                    <i class="bi bi-bar-chart me-1"></i> Institutional Holders
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link fw-bold" id="us-13f-tab" data-bs-toggle="tab" data-bs-target="#us-13f-panel" type="button" role="tab" aria-selected="false">
                    <i class="bi bi-building me-1"></i> SEC 13F Holdings
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link fw-bold" id="us-insider-tab" data-bs-toggle="tab" data-bs-target="#us-insider-panel" type="button" role="tab" aria-selected="false">
                    <i class="bi bi-person-badge me-1"></i> Insider Trades
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link fw-bold" id="us-financial-tab" data-bs-toggle="tab" data-bs-target="#us-financial-panel" type="button" role="tab" aria-selected="false">
                    <i class="bi bi-file-earmark-spreadsheet me-1"></i> Financial Data
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link fw-bold" id="us-moneyflow-tab" data-bs-toggle="tab" data-bs-target="#us-moneyflow-panel" type="button" role="tab" aria-selected="false">
                    <i class="bi bi-grid-3x3-gap-fill me-1"></i> US Money Flow Heatmap
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link fw-bold" id="us-master-tab" data-bs-toggle="tab" data-bs-target="#us-master-panel" type="button" role="tab" aria-selected="false">
                    <i class="bi bi-award me-1"></i> 大師選股
                </button>
            </li>
        </ul>

        <div class="tab-content" id="us-sub-tabs-content">

            <!-- Sub Tab 1: Institutional Holders (existing content preserved) -->
            <div class="tab-pane fade show active" id="us-holders-panel" role="tabpanel" aria-labelledby="us-holders-tab">
                <div class="row">
                    <div class="col-12 py-4 text-center bg-white rounded shadow-sm">
                        <p id="us-loading-text" class="text-muted mb-0">Fetching data for US markets...</p>
                        <div id="us-charts-container" class="mt-4 row text-start">
                            <!-- US Charts will be injected here via JS (existing logic) -->
                        </div>
                    </div>
                </div>
            </div>

            <!-- Sub Tab 2: SEC 13F Holdings -->
            <div class="tab-pane fade" id="us-13f-panel" role="tabpanel" aria-labelledby="us-13f-tab">
                <div class="card border-0 shadow-sm">
                    <div class="card-header bg-white border-0 py-3 d-flex flex-wrap justify-content-between align-items-center gap-3">
                        <div class="d-flex align-items-center">
                            <div class="bg-primary bg-opacity-10 p-2 rounded me-3">
                                <i class="bi bi-building text-primary fs-5"></i>
                            </div>
                            <div>
                                <h5 class="card-title fw-bold mb-0">13F Institutional Holdings</h5>
                                <small class="text-muted" id="sec-13f-period">SEC official filings</small>
                            </div>
                        </div>
                        
                        <!-- Institution Dropdown Selector -->
                        <div class="d-flex align-items-center gap-2">
                            <label for="chipsInstitutionSelector" class="form-label mb-0 small fw-bold text-muted">選擇投資機構:</label>
                            <select id="chipsInstitutionSelector" class="form-select form-select-sm" style="min-width: 250px;">
                                {% for cik, inst in known_institutions.items %}
                                    <option value="{{ cik }}" {% if current_cik == cik %}selected{% endif %}>{{ inst.name_zh }}</option>
                                {% endfor %}
                            </select>
                        </div>
                        
                        <span class="badge bg-primary rounded-pill px-3 py-2" id="sec-13f-count">0 records</span>
                    </div>
                    <div class="card-body p-0">
                        <div id="sec-13f-loader" class="text-center py-5">
                            <div class="spinner-border text-primary" role="status"></div>
                            <p class="mt-2 text-muted">Loading institution 13F data...</p>
                        </div>
                        <div id="sec-13f-empty" class="text-center py-5" style="display:none;">
                            <i class="bi bi-inbox text-secondary display-4"></i>
                            <p class="mt-3 text-muted">No 13F data found for this institution.<br>Click "Sync 13F" to fetch from SEC EDGAR.</p>
                        </div>
                        <div class="table-responsive" id="sec-13f-table-wrap" style="display:none; max-height: 600px; overflow-y: auto;">
                            <table class="table table-hover table-striped mb-0 align-middle">
                                <thead class="table-light sticky-top">
                                    <tr>
                                        <th class="ps-4">Ticker</th>
                                        <th>Security Name</th>
                                        <th>Type</th>
                                        <th class="text-end">Shares</th>
                                        <th class="text-end">Value (USD)</th>
                                        <th class="text-end">Weight (占比)</th>
                                        <th class="text-end">Quarterly Change</th>
                                        <th>Action</th>
                                    </tr>
                                </thead>
