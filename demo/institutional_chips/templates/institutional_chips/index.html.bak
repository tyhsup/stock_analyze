            </div>

            <!-- Sub Tab 4: Financial Data (XBRL) -->
            <div class="tab-pane fade" id="us-financial-panel" role="tabpanel" aria-labelledby="us-financial-tab">
                <div class="card border-0 shadow-sm">
                    <div class="card-header bg-white border-0 py-3 d-flex justify-content-between align-items-center">
                        <div class="d-flex align-items-center">
                            <div class="bg-success bg-opacity-10 p-2 rounded me-3">
                                <i class="bi bi-file-earmark-spreadsheet text-success fs-5"></i>
                            </div>
                            <div>
                                <h5 class="card-title fw-bold mb-0">XBRL Financial Metrics (10-K/10-Q)</h5>
                                <small class="text-muted">Standardized financial concepts from SEC filings</small>
                            </div>
                        </div>
                        <span class="badge bg-success rounded-pill px-3 py-2" id="sec-fin-count">0 records</span>
                    </div>
                    <div class="card-body p-0">
                        <div id="sec-fin-loader" class="text-center py-5">
                            <div class="spinner-border text-success" role="status"></div>
                            <p class="mt-2 text-muted">Financial data will load when you switch to this tab...</p>
                        </div>
                        <div id="sec-fin-empty" class="text-center py-5" style="display:none;">
                            <i class="bi bi-inbox text-secondary display-4"></i>
                            <p class="mt-3 text-muted">No financial data found.<br>Click "Sync Insider/Fin" to fetch XBRL data.</p>
                        </div>
                        <div class="table-responsive" id="sec-fin-table-wrap" style="display:none; max-height: 600px; overflow-y: auto;">
                            <table class="table table-hover table-striped mb-0 align-middle">
                                <thead class="table-light sticky-top">
                                    <tr>
                                        <th class="ps-4">Period End</th>
                                        <th>Concept</th>
                                        <th class="text-end">Value (USD)</th>
                                        <th>Report Type</th>
