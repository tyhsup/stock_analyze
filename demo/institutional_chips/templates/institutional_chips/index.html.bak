            <!-- Sub Tab 6: 大師選股 -->
            <div class="tab-pane fade" id="us-master-panel" role="tabpanel" aria-labelledby="us-master-tab">
                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-header bg-white border-0 py-3 d-flex flex-wrap justify-content-between align-items-center gap-3">
                        <div class="d-flex align-items-center">
                            <div class="bg-primary bg-opacity-10 p-2 rounded me-3">
                                <i class="bi bi-award text-primary fs-5"></i>
                            </div>
                            <div>
                                <h5 class="card-title fw-bold mb-0" id="us-master-title">大師選股 - 巴菲特價值投資法則 (美股)</h5>
                                <small class="text-muted" id="us-master-desc">篩選標準：ROE &ge; 15% | 營業毛利率 &ge; 30% | 負債比率 &le; 50% | 淨利正成長</small>
                            </div>
                        </div>
                        <div class="d-flex align-items-center gap-2 flex-wrap">
                            <label for="us-master-select" class="form-label mb-0 small fw-bold text-muted">選擇流派:</label>
                            <select id="us-master-select" class="form-select form-select-sm rounded-pill px-3" style="width: 220px;">
                                <option value="buffett" selected>巴菲特 (價值投資)</option>
                                <option value="lynch">彼得·林區 (合理成長)</option>
                                <option value="oneil">威廉·歐尼爾 (CANSLIM)</option>
