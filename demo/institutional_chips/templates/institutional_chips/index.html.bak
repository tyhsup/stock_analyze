                                        <th id="th-us-metrics-1">ROE</th>
                                        <th id="th-us-metrics-2">營業毛利率</th>
                                        <th id="th-us-metrics-3">負債比率</th>
                                        <th id="th-us-metrics-4">淨利成長率</th>
                                        <th class="pe-4 text-end" style="width: 150px;">綜合評分</th>
                                    </tr>
