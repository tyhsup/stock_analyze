            <!-- Sub Tab 5: US Money Flow Heatmap -->
            <div class="tab-pane fade" id="us-moneyflow-panel" role="tabpanel" aria-labelledby="us-moneyflow-tab">
                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-header bg-white border-0 py-3 d-flex flex-wrap justify-content-between align-items-center gap-3">
                        <div class="d-flex align-items-center">
                            <div class="bg-info bg-opacity-10 p-2 rounded me-3">
                                <i class="bi bi-grid-3x3-gap-fill text-info fs-5"></i>
                            </div>
                            <div>
                                <h5 class="card-title fw-bold mb-0">US Stock Money Flow Heatmap</h5>
                                <small class="text-muted">Node size = Daily volume value (M USD), color = Net Flow Ratio % (CLV weighted)</small>
                            </div>
                        </div>
                        <!-- 天數與數量控制項 -->
                        <div class="d-flex align-items-center gap-2">
                            <label for="us-mf-days" class="form-label mb-0 small fw-bold text-muted">Days:</label>
                            <select id="us-mf-days" class="form-select form-select-sm rounded-pill px-3" style="width: 90px;">
                                <option value="1">1 Day</option>
                                <option value="5" selected>5 Days</option>
                                <option value="10">10 Days</option>
                                <option value="20">20 Days</option>
                            </select>
                            <label for="us-mf-limit" class="form-label mb-0 small fw-bold text-muted ms-2">Limit:</label>
                            <select id="us-mf-limit" class="form-select form-select-sm rounded-pill px-3" style="width: 100px;">
                                <option value="10">Top 10</option>
                                <option value="20" selected>Top 20</option>
                                <option value="50">Top 50</option>
                            </select>
                        </div>
                    </div>
                    <div class="card-body">
                        <div id="us-moneyflow-loader" class="text-center py-5" style="display:none;">
                            <div class="spinner-border text-info" role="status"></div>
                            <p class="mt-2 text-muted">Calculating US stock money flow...</p>
                        </div>
                        <div id="us-moneyflow-empty" class="text-center py-5" style="display:none;">
                            <i class="bi bi-inbox text-secondary display-4"></i>
                            <p class="mt-3 text-muted">No money flow data calculated.</p>
