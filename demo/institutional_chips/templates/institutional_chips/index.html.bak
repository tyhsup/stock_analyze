                        <span class="badge bg-warning text-dark rounded-pill px-3 py-2" id="sec-insider-count">0 records</span>
                    </div>
                    <div class="card-body p-0">
                        <div id="sec-insider-loader" class="text-center py-5">
                            <div class="spinner-border text-warning" role="status"></div>
                            <p class="mt-2 text-muted">Select a ticker and switch to this tab to load data...</p>
                        </div>
                        <div id="sec-insider-empty" class="text-center py-5" style="display:none;">
                            <i class="bi bi-inbox text-secondary display-4"></i>
                            <p class="mt-3 text-muted">No insider trades found.<br>Click "Sync Insider/Fin" to fetch from SEC EDGAR.</p>
                        </div>
                        <div class="table-responsive" id="sec-insider-table-wrap" style="display:none; max-height: 600px; overflow-y: auto;">
                            <table class="table table-hover table-striped mb-0 align-middle">
                                <thead class="table-light sticky-top">
                                    <tr>
                                        <th class="ps-4">Filing Date</th>
                                        <th>Insider / Title</th>
                                        <th class="text-end">Shares</th>
                                        <th class="text-end">Price</th>
                                        <th class="text-end">Total Value</th>
                                        <th>Code</th>
                                    </tr>
                                </thead>
