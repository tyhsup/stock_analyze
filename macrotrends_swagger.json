{
  "openapi": "3.0.3",
  "info": {
    "title": "Macrotrends API",
    "description": "提供美股損益表、資產負債表、現金流量表及財務比率數據的 API，整合本地 MySQL 快取與 yfinance 備援機制。",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://127.0.0.1:8000"
    }
  ],
  "paths": {
    "/api/macrotrends/financials": {
      "get": {
        "summary": "取得美股財務報表數據",
        "description": "取得指定美股的年度或季度損益表、資產負債表或現金流量表數據。",
        "operationId": "getFinancials",
        "parameters": [
          {
            "name": "symbol",
            "in": "query",
            "required": true,
            "description": "美股股票代號 (例如: AAPL)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "type",
            "in": "query",
            "required": true,
            "description": "報表類型 (income-statement, balance-sheet, cash-flow)",
            "schema": {
              "type": "string",
              "enum": [
                "income-statement",
                "balance-sheet",
                "cash-flow"
              ]
            }
          },
          {
            "name": "frequency",
            "in": "query",
            "required": false,
            "description": "報表頻率 (annual, quarterly)",
            "schema": {
              "type": "string",
              "enum": [
                "annual",
                "quarterly"
              ],
              "default": "annual"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "成功取得財務數據",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/FinancialRecord"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/macrotrends/ratios": {
      "get": {
        "summary": "取得美股財務比率數據",
        "description": "取得指定美股的本益比、股價淨值比、債務股本比與利潤率等財務比率歷史數據。",
        "operationId": "getRatios",
        "parameters": [
          {
            "name": "symbol",
            "in": "query",
            "required": true,
            "description": "美股股票代號 (例如: AAPL)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "type",
            "in": "query",
            "required": true,
            "description": "比率類型 (pe-ratio, price-book, debt-equity, margins)",
            "schema": {
              "type": "string",
              "enum": [
                "pe-ratio",
                "price-book",
                "debt-equity",
                "margins"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "成功取得財務比率數據",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/RatioRecord"
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "FinancialRecord": {
        "type": "object",
        "properties": {
          "symbol": {
            "type": "string",
            "description": "股票代碼"
          },
          "year": {
            "type": "integer",
            "description": "年度"
          },
          "quarter": {
            "type": "integer",
            "description": "季度"
          },
          "statement_type": {
            "type": "string",
            "description": "報表類型 (IS, BS, CF)"
          },
          "item_name": {
            "type": "string",
            "description": "科目名稱"
          },
          "amount": {
            "type": "number",
            "description": "金額"
          }
        },
        "required": [
          "symbol",
          "year",
          "quarter",
          "statement_type",
          "item_name",
          "amount"
        ]
      },
      "RatioRecord": {
        "type": "object",
        "properties": {
          "symbol": {
            "type": "string",
            "description": "股票代碼"
          },
          "date": {
            "type": "string",
            "description": "日期 (YYYY-MM-DD)"
          },
          "ratio_name": {
            "type": "string",
            "description": "比率項目名稱"
          },
          "value": {
            "type": "number",
            "description": "比率數值"
          }
        },
        "required": [
          "symbol",
          "date",
          "ratio_name",
          "value"
        ]
      }
    }
  }
}
